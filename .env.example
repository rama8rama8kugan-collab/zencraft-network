# Database
DATABASE_URL=postgresql://user:password@localhost:5432/zencraft

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_MINECRAFT_API=https://api.mojang.com
NEXT_PUBLIC_CRAFATAR_API=https://crafatar.com

# Authentication
JWT_SECRET=your_jwt_secret_key_here
ADMIN_PASSWORD_SALT=10

# Payment Gateway - Razorpay
NEXT_PUBLIC_RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_secret

# Discord Integration
NEXT_PUBLIC_DISCORD_INVITE=https://discord.gg/yourcode
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_guild_id

# Server Info
NEXT_PUBLIC_SERVER_IP=play.zencraft.in
NEXT_PUBLIC_JAVA_PORT=25565
NEXT_PUBLIC_BEDROCK_PORT=19132

# SEO
NEXT_PUBLIC_SITE_URL=https://zencraft.in
NEXT_PUBLIC_SITE_NAME=ZenCraft Network

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
